# LLM Diff — Environment Variables
#
# You only need ONE API key to get started.
# The default provider is Groq (free tier available).
#
# To switch providers, change the "model" and "judge_model" strings
# in your YAML test file — no code changes required.
#
# Provider → model string format → required key
#   Groq    → groq/llama3-70b-8192          → GROQ_API_KEY
#   OpenAI  → openai/gpt-4o-mini            → OPENAI_API_KEY
#   Anthropic → anthropic/claude-3-haiku-20240307 → ANTHROPIC_API_KEY
#   Ollama  → ollama/llama3                 → (none, runs locally)
#   Google  → gemini/gemini-2.0-flash       → GOOGLE_API_KEY

GROQ_API_KEY=   # free at console.groq.com
ANTHROPIC_API_KEY=            # optional
OPENAI_API_KEY=               # optional
GOOGLE_API_KEY=               # optional — free at aistudio.google.com

LLMDIFF_DB_PATH=~/.llmdiff/history.db   # where run history is stored
LLMDIFF_PORT=7331                       # port for `llmdiff serve`

# Judge tuning
LLMDIFF_JUDGE_VOTES=1    # calls per criterion: 1=fast, 3=reliable majority vote
LLMDIFF_JUDGE_SLEEP=0    # seconds between judge calls; set to 6 for Gemini free tier (10 RPM)
