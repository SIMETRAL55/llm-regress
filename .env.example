# LLM Diff — Environment Variables
#
# You only need ONE API key to get started.
# The default provider is Groq (free tier available).
#
# To switch providers, change the "model" and "judge_model" strings
# in your YAML test file — no code changes required.
#
# Provider → model string format → required key #can use any models these models string are for example only
#   Groq    → groq/llama3-70b-8192          → GROQ_API_KEY
#   OpenAI  → openai/gpt-4o-mini            → OPENAI_API_KEY
#   Anthropic → anthropic/claude-3-haiku-20240307 → ANTHROPIC_API_KEY
#   Google  → gemini/gemini-2.0-flash       → GOOGLE_API_KEY

# use as per the model requirements above; you can set multiple keys if you want to test multiple providers
GROQ_API_KEY=                 
ANTHROPIC_API_KEY=            # optional
OPENAI_API_KEY=               # optional
GOOGLE_API_KEY=               # optional — free at aistudio.google.com
# for Google Gemini, you also need to set VERTEXAI_PROJECT and VERTEXAI_LOCATION below
VERTEXAI_PROJECT=   # set this to your Google Cloud project ID if using Google Gemini                                   
VERTEXAI_LOCATION=  # region

LLMREGRESS_DB_PATH=~/.llmregress/history.db   # where run history is stored
LLMREGRESS_PORT=7331                          # port for `llmregress serve`

# Judge tuning
LLMREGRESS_JUDGE_VOTES=1    # calls per criterion: 1=fast, 3=reliable majority vote